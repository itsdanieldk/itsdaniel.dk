---
import type { CollectionEntry } from "astro:content";
import { readingTime } from "@lib/utils";
import ArrowIcon from "@components/ArrowIcon.astro";

type Props = {
  entry: CollectionEntry<"notes"> | CollectionEntry<"projects">;
};

const { entry } = Astro.props;
const meta = [...(entry.collection === "notes" ? [readingTime(entry.body ?? "")] : []), ...(entry.data.tags ?? [])];
---

<a href={`/${entry.collection}/${entry.id}/`} class="hover-card relative group flex py-4 px-5 pr-12 rounded-lg">
  <div class="flex flex-col flex-1">
    <div class="font-semibold text-lg">
      {entry.data.title}
    </div>
    <div class="text-base">
      {entry.data.description}
    </div>
    {meta.length > 0 && <div class="mt-1 text-sm text-black/40 dark:text-white/40">{meta.join(" · ")}</div>}
  </div>
  <ArrowIcon class="absolute top-1/2 right-3 -translate-y-1/2 size-6 rotate-180" />
</a>
