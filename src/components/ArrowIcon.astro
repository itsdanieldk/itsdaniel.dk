---
import { cn } from "@lib/utils";

type Props = {
  class?: string;
};

const { class: className } = Astro.props;
---

<!-- Left-pointing animated arrow; rotate at the call site (rotate-180 = right, rotate-90 = up). Requires a `group` ancestor for the hover animation. -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" class={cn("stroke-2 fill-none stroke-current", className)}>
  <line
    x1="5"
    y1="12"
    x2="19"
    y2="12"
    class="translate-x-2 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out"></line>
  <polyline points="12 5 5 12 12 19" class="translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out"
  ></polyline>
</svg>
