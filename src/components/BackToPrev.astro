---
type Props = {
  href: string;
};

const { href } = Astro.props;
---

<a
  id="back-to-prev"
  href={href}
  class="relative group w-fit flex pl-7 pr-3 py-1.5 flex-nowrap rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    aria-hidden="true"
    class="absolute top-1/2 left-2 -translate-y-1/2 size-4 stroke-2 fill-none stroke-current"
  >
    <line
      x1="5"
      y1="12"
      x2="19"
      y2="12"
      class="translate-x-2 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out"
    ></line>
    <polyline points="12 5 5 12 12 19" class="translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out"
    ></polyline>
  </svg>
  <div class="text-sm">
    <slot />
  </div>
</a>

<script>
  const NAV_PATH_KEY = "nav.currentPath";
  const NAV_INTERNAL_KEY = "nav.hasInternalNav";

  function resetNavTrackingIfExternal() {
    try {
      if (!document.referrer || new URL(document.referrer).origin !== window.location.origin) {
        sessionStorage.removeItem(NAV_PATH_KEY);
        sessionStorage.removeItem(NAV_INTERNAL_KEY);
      }
    } catch (e) {
      console.warn("sessionStorage not available:", e);
    }
  }

  function recordNavPath() {
    try {
      const currentPath = sessionStorage.getItem(NAV_PATH_KEY);
      if (currentPath && currentPath !== window.location.pathname) {
        sessionStorage.setItem(NAV_INTERNAL_KEY, "true");
      }
      sessionStorage.setItem(NAV_PATH_KEY, window.location.pathname);
    } catch (e) {
      console.warn("sessionStorage not available:", e);
    }
  }

  function hasInternalNavigation() {
    try {
      return sessionStorage.getItem(NAV_INTERNAL_KEY) === "true";
    } catch {
      return false;
    }
  }

  resetNavTrackingIfExternal();

  let controller: AbortController | null = null;

  function init() {
    controller?.abort();
    recordNavPath();

    const link = document.getElementById("back-to-prev");
    if (!link) return;
    controller = new AbortController();
    link.addEventListener(
      "click",
      (event) => {
        if (!(event instanceof MouseEvent)) return;
        if (event.defaultPrevented) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) return;
        if (!hasInternalNavigation()) return;
        if (window.history.length <= 1) return;
        event.preventDefault();
        window.history.back();
      },
      { signal: controller.signal }
    );
  }

  document.addEventListener("DOMContentLoaded", init);
  document.addEventListener("astro:after-swap", init);
</script>
