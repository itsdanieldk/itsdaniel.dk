---
import "../styles/global.css";
import "@fontsource/fira-sans/400.css";
import "@fontsource/fira-sans/500.css";
import "@fontsource/fira-sans/600.css";
import "@fontsource/fira-sans/700.css";
import "@fontsource/fira-sans/400-italic.css";
import "@fontsource-variable/fira-code";
import "@fontsource/metamorphous/400.css";

import { ClientRouter } from "astro:transitions";
import { SITE } from "@consts";

interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = "/itsdaniel.png", ogType = "website" } = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Daniel Larsen" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:locale" content="en_US" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<ClientRouter />

<!-- RSS Link -->
<link rel="alternate" type="application/rss+xml" title={SITE.NAME} href={new URL("rss.xml", Astro.site)} />

<!-- Theme Color -->
<meta name="theme-color" content="#f5f5f4" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#1c1917" media="(prefers-color-scheme: dark)" />

<script>
  import type { TransitionBeforeSwapEvent } from "astro:transitions/client";
  document.addEventListener("astro:before-swap", (e) => {
    const event = e as TransitionBeforeSwapEvent;
    [...event.newDocument.head.querySelectorAll(`link[as="font"]`)].forEach((link) => link.remove());
    event.newDocument.documentElement.classList.toggle("dark", document.documentElement.classList.contains("dark"));
  });
</script>

<script>
  function initCopyCodeButtons() {
    document.querySelectorAll("article pre code").forEach((codeBlock) => {
      const pre = codeBlock.parentElement;
      if (!pre || pre.querySelector(".copy-code-button")) return;

      const button = document.createElement("button");
      button.className = "copy-code-button";
      button.setAttribute("aria-label", "Copy code");
      button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;

      button.addEventListener("click", async () => {
        const text = codeBlock.textContent ?? "";
        await navigator.clipboard.writeText(text);
        button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        setTimeout(() => {
          button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
        }, 2000);
      });

      pre.appendChild(button);
    });
  }

  function initHeadingAnchors() {
    document.querySelectorAll("article :is(h2, h3, h4)[id]").forEach((heading) => {
      if (heading.querySelector(".heading-anchor")) return;
      const anchor = document.createElement("a");
      anchor.className = "heading-anchor";
      anchor.href = `#${heading.id}`;
      anchor.setAttribute("aria-label", `Link to ${heading.textContent}`);
      anchor.textContent = "#";
      heading.prepend(anchor);
    });
  }

  function initReadingProgress() {
    let bar = document.getElementById("reading-progress");
    const isArticlePage = /^\/(notes|projects)\/[^/]+/.test(window.location.pathname);

    if (!isArticlePage) {
      bar?.remove();
      return;
    }

    if (!bar) {
      bar = document.createElement("div");
      bar.id = "reading-progress";
      document.body.prepend(bar);
    }

    function updateProgress() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
      if (bar) bar.style.width = `${progress}%`;
    }

    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();
  }

  document.addEventListener("DOMContentLoaded", () => {
    initCopyCodeButtons();
    initHeadingAnchors();
    initReadingProgress();
  });

  document.addEventListener("astro:after-swap", () => {
    initCopyCodeButtons();
    initHeadingAnchors();
    initReadingProgress();
  });
</script>

<script is:inline>
  document.documentElement.classList.add("js-enabled");

  let abortController = null;
  const NAV_PATH_KEY = "nav.currentPath";
  const NAV_INTERNAL_KEY = "nav.hasInternalNav";

  function resetNavTrackingIfExternal() {
    try {
      if (!document.referrer || new URL(document.referrer).origin !== window.location.origin) {
        sessionStorage.removeItem(NAV_PATH_KEY);
        sessionStorage.removeItem(NAV_INTERNAL_KEY);
      }
    } catch (e) {
      console.warn("sessionStorage not available:", e);
    }
  }

  function recordNavPath() {
    try {
      const currentPath = sessionStorage.getItem(NAV_PATH_KEY);
      if (currentPath && currentPath !== window.location.pathname) {
        sessionStorage.setItem(NAV_INTERNAL_KEY, "true");
      }
      sessionStorage.setItem(NAV_PATH_KEY, window.location.pathname);
    } catch (e) {
      console.warn("sessionStorage not available:", e);
    }
  }

  function hasInternalNavigation() {
    try {
      return sessionStorage.getItem(NAV_INTERNAL_KEY) === "true";
    } catch {
      return false;
    }
  }

  resetNavTrackingIfExternal();

  function init() {
    if (abortController) {
      abortController.abort();
    }

    abortController = new AbortController();
    const signal = abortController.signal;

    recordNavPath();

    onScroll();
    animate();

    const backToTop = document.getElementById("back-to-top");
    backToTop?.addEventListener("click", (event) => scrollToTop(event), { signal });

    const backToPrev = document.getElementById("back-to-prev");
    backToPrev?.addEventListener(
      "click",
      (event) => {
        if (!(event instanceof MouseEvent)) return;
        if (event.defaultPrevented) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) return;
        if (!hasInternalNavigation()) return;
        if (window.history.length <= 1) return;
        event.preventDefault();
        window.history.back();
      },
      { signal }
    );

    const lightThemeButton = document.getElementById("light-theme-button");
    lightThemeButton?.addEventListener(
      "click",
      () => {
        try {
          localStorage.setItem("theme", "light");
        } catch (e) {
          console.warn("localStorage not available:", e);
        }
        toggleTheme(false);
        updateThemeButtonStates();
      },
      { signal }
    );

    const darkThemeButton = document.getElementById("dark-theme-button");
    darkThemeButton?.addEventListener(
      "click",
      () => {
        try {
          localStorage.setItem("theme", "dark");
        } catch (e) {
          console.warn("localStorage not available:", e);
        }
        toggleTheme(true);
        updateThemeButtonStates();
      },
      { signal }
    );

    const systemThemeButton = document.getElementById("system-theme-button");
    systemThemeButton?.addEventListener(
      "click",
      () => {
        try {
          localStorage.setItem("theme", "system");
        } catch (e) {
          console.warn("localStorage not available:", e);
        }
        toggleTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);
        updateThemeButtonStates();
      },
      { signal }
    );

    window.matchMedia("(prefers-color-scheme: dark)").addEventListener(
      "change",
      (event) => {
        let userTheme;
        try {
          userTheme = localStorage.theme;
        } catch {
          userTheme = null;
        }

        if (userTheme === "system" || !userTheme) {
          toggleTheme(event.matches);
        }
      },
      { signal }
    );

    document.addEventListener("scroll", onScroll, { signal });
    updateThemeButtonStates();
  }

  function animate() {
    const animateElements = document.querySelectorAll(".animate");

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      animateElements.forEach((element) => element.classList.add("show"));
      return;
    }

    const delay = 100;
    const maxDelay = 1500;
    animateElements.forEach((element, index) => {
      setTimeout(
        () => {
          element.classList.add("show");
        },
        Math.min(index * delay, maxDelay)
      );
    });
  }

  function onScroll() {
    if (window.scrollY > 0) {
      document.documentElement.classList.add("scrolled");
    } else {
      document.documentElement.classList.remove("scrolled");
    }
  }

  function scrollToTop(event) {
    event.preventDefault();
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  }

  function toggleTheme(dark) {
    const css = document.createElement("style");

    css.appendChild(
      document.createTextNode(
        `* {
             -webkit-transition: none !important;
             -moz-transition: none !important;
             -o-transition: none !important;
             -ms-transition: none !important;
             transition: none !important;
          }
        `
      )
    );

    document.head.appendChild(css);

    if (dark) {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }

    void window.getComputedStyle(css).opacity;
    document.head.removeChild(css);
  }

  function updateThemeButtonStates() {
    let userTheme;
    try {
      userTheme = localStorage.theme;
    } catch {
      userTheme = null;
    }

    const lightButton = document.getElementById("light-theme-button");
    const darkButton = document.getElementById("dark-theme-button");
    const systemButton = document.getElementById("system-theme-button");

    lightButton?.setAttribute("aria-pressed", "false");
    darkButton?.setAttribute("aria-pressed", "false");
    systemButton?.setAttribute("aria-pressed", "false");

    if (userTheme === "light") {
      lightButton?.setAttribute("aria-pressed", "true");
    } else if (userTheme === "dark") {
      darkButton?.setAttribute("aria-pressed", "true");
    } else {
      systemButton?.setAttribute("aria-pressed", "true");
    }
  }

  function preloadTheme() {
    let userTheme;
    try {
      userTheme = localStorage.theme;
    } catch {
      console.warn("localStorage not available, using system preference");
      userTheme = null;
    }

    if (userTheme === "light" || userTheme === "dark") {
      toggleTheme(userTheme === "dark");
    } else {
      toggleTheme(window.matchMedia("(prefers-color-scheme: dark)").matches);
    }

    updateThemeButtonStates();
  }

  document.addEventListener("DOMContentLoaded", () => init());
  document.addEventListener("astro:after-swap", () => init());
  preloadTheme();
</script>
