---
import type { CollectionEntry } from "astro:content";
import ArrowIcon from "@components/ArrowIcon.astro";

type Props = {
  prev?: CollectionEntry<"notes"> | CollectionEntry<"projects">;
  next?: CollectionEntry<"notes"> | CollectionEntry<"projects">;
};

const { prev, next } = Astro.props;
---

{
  (prev || next) && (
    <nav class="animate flex gap-4 mt-16" aria-label="Previous and next posts">
      <div class="flex-1">
        {prev && (
          <a href={`/${prev.collection}/${prev.id}/`} class="hover-card group flex flex-col py-3 px-4 rounded-lg">
            <span class="text-xs text-black/40 dark:text-white/40 mb-1 inline-flex items-center gap-1">
              <ArrowIcon class="size-3.5" />
              Previous
            </span>
            <span class="text-sm font-semibold line-clamp-1">{prev.data.title}</span>
          </a>
        )}
      </div>
      <div class="flex-1">
        {next && (
          <a href={`/${next.collection}/${next.id}/`} class="hover-card group flex flex-col py-3 px-4 rounded-lg">
            <span class="text-xs text-black/40 dark:text-white/40 mb-1 inline-flex items-center gap-1">
              Next
              <ArrowIcon class="size-3.5 rotate-180" />
            </span>
            <span class="text-sm font-semibold line-clamp-1">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  )
}
