---
import { cn } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  class?: string;
};

const { href, external = false, class: className, ...rest } = Astro.props;
---

<a
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class={cn("hover-card inline-flex items-center justify-center px-6 py-3 rounded-lg", className)}
  {...rest}
>
  <slot />
</a>
