---
import { type CollectionEntry, render } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import CopyLinkButton from "@components/CopyLinkButton.astro";
import ArticleEnhancements from "@components/ArticleEnhancements.astro";
import PostNavigation from "@components/PostNavigation.astro";
import Tag from "@components/Tag.astro";
import BackToPrev from "@components/BackToPrev.astro";
import { readingTime, slugifyTag } from "@lib/utils";

type Entry = CollectionEntry<"notes"> | CollectionEntry<"projects">;

type Props = {
  entry: Entry;
  prev?: Entry;
  next?: Entry;
  backHref: string;
  backLabel: string;
  jsonLd: Record<string, unknown>;
};

const { entry, prev, next, backHref, backLabel, jsonLd } = Astro.props;
const { Content } = await render(entry);
---

<PageLayout title={entry.data.title} description={entry.data.description} ogType="article">
  <ArticleEnhancements />
  <Container>
    <div class="animate">
      <BackToPrev href={backHref}>{backLabel}</BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={entry.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(entry.body ?? "")}
        </div>
        {
          entry.data.updatedDate && entry.data.updatedDate.getTime() !== entry.data.date.getTime() && (
            <>
              &bull;
              <div class="font-base text-sm">
                Updated: <FormattedDate date={entry.data.updatedDate} />
              </div>
            </>
          )
        }
      </div>
      <div class="animate flex items-center gap-2">
        <h1 class="text-2xl font-semibold text-black dark:text-white">
          {entry.data.title}
        </h1>
        <CopyLinkButton />
      </div>
      {
        entry.data.tags && entry.data.tags.length > 0 && (
          <div class="animate flex flex-wrap gap-1.5">
            {entry.data.tags.map((tag) => (
              <Tag tag={tag} href={`/tags/${slugifyTag(tag)}/`} />
            ))}
          </div>
        )
      }
      <slot />
    </div>
    <article class="animate">
      <Content />
    </article>
    <PostNavigation prev={prev} next={next} />
  </Container>
</PageLayout>

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
