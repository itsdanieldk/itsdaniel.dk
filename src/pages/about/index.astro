---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import SocialLinks from "@components/SocialLinks.astro";
import { ABOUT, SITE, SOCIALS } from "@consts";

const siteUrl = Astro.site?.toString() ?? "";
---

<PageLayout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <Container>
    <div class="space-y-8">
      <h1 class="animate font-semibold text-black dark:text-white">About</h1>
      <article class="space-y-4">
        <p class="animate">
          I'm Daniel Larsen, a software engineer from Denmark. F# is my favorite language, C# is the one I write most days, and functional
          programming shapes how I use both.
        </p>
        <p class="animate">
          I'm responsible for Backend Development at <Link href="https://clever.dk/">Clever</Link>, where I build the systems behind EV
          charging in Denmark: .NET services running on Azure. On the side I maintain <Link href="/projects/fio/">FIO</Link>, a functional
          effect system for F# that started as my thesis at DTU in 2022. Some of what I learn ends up here as notes; the rest I share
          through demos.
        </p>
        <p class="animate">
          Outside programming, I run and lift weights, explore new metal bands, practice guitar, <Link href="/fragrances/"
            >collect fragrances</Link
          >, and read Norse mythology and history.
        </p>
        <p class="animate">Questions or want to connect? Reach out anytime.</p>
      </article>

      <picture class="animate block mx-auto w-[232px] h-[232px]">
        <source type="image/webp" srcset="/itsdaniel-400.webp 400w, /itsdaniel-600.webp 600w, /itsdaniel-800.webp 800w" sizes="232px" />
        <img
          src="/itsdaniel.png"
          srcset="/itsdaniel-400.png 400w, /itsdaniel-600.png 600w, /itsdaniel-800.png 800w"
          sizes="232px"
          alt="Picture of Daniel Larsen"
          loading="lazy"
          decoding="async"
          width="232"
          height="232"
          class="w-[232px] h-[232px] object-cover rounded-full"
        />
      </picture>

      <SocialLinks />
    </div>
  </Container>
</PageLayout>

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.AUTHOR,
    url: `${siteUrl}about/`,
    image: `${siteUrl}itsdaniel.png`,
    jobTitle: "Software Engineer",
    worksFor: {
      "@type": "Organization",
      name: "Clever",
    },
    alumniOf: {
      "@type": "CollegeOrUniversity",
      name: "Technical University of Denmark",
    },
    knowsAbout: ["Functional Programming", "Distributed Systems", "Software Architecture", "Cloud Computing", "F#", "C#", ".NET", "Azure"],
    sameAs: SOCIALS.map((social) => social.HREF),
  })}
/>
