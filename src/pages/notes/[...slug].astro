---
import type { CollectionEntry } from "astro:content";
import ArticleLayout from "@layouts/ArticleLayout.astro";
import { getAllNotes } from "@lib/collections";
import { SITE } from "@consts";

export async function getStaticPaths() {
  const notes = await getAllNotes();
  return notes.map((note, index) => ({
    params: { slug: note.id },
    props: { entry: note, prev: notes[index + 1], next: notes[index - 1] },
  }));
}
type Props = { entry: CollectionEntry<"notes">; prev?: CollectionEntry<"notes">; next?: CollectionEntry<"notes"> };

const { entry: note, prev, next } = Astro.props;
const siteUrl = Astro.site?.toString() ?? "";
const author = { "@type": "Person", name: SITE.AUTHOR, url: siteUrl };
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: note.data.title,
  description: note.data.description,
  datePublished: note.data.date.toISOString(),
  dateModified: (note.data.updatedDate ?? note.data.date).toISOString(),
  author,
  publisher: author,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `${siteUrl}notes/${note.id}/`,
  },
};
---

<ArticleLayout entry={note} prev={prev} next={next} backHref="/notes/" backLabel="Back to notes" jsonLd={jsonLd} />
