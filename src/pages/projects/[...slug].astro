---
import type { CollectionEntry } from "astro:content";
import ArticleLayout from "@layouts/ArticleLayout.astro";
import Link from "@components/Link.astro";
import { getAllProjects } from "@lib/collections";
import { SITE } from "@consts";

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: { entry: project, prev: projects[index + 1], next: projects[index - 1] },
  }));
}
type Props = { entry: CollectionEntry<"projects">; prev?: CollectionEntry<"projects">; next?: CollectionEntry<"projects"> };

const { entry: project, prev, next } = Astro.props;
const siteUrl = Astro.site?.toString() ?? "";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.data.title,
  description: project.data.description,
  datePublished: project.data.date.toISOString(),
  dateModified: (project.data.updatedDate ?? project.data.date).toISOString(),
  author: {
    "@type": "Person",
    name: SITE.AUTHOR,
    url: siteUrl,
  },
  ...(project.data.demoURL && { url: project.data.demoURL }),
  ...(project.data.repoURL && { codeRepository: project.data.repoURL }),
};
---

<ArticleLayout entry={project} prev={prev} next={next} backHref="/projects/" backLabel="Back to projects" jsonLd={jsonLd}>
  {
    (project.data.demoURL || project.data.repoURL) && (
      <nav class="animate flex gap-1">
        {project.data.demoURL && (
          <Link href={project.data.demoURL} external>
            demo
          </Link>
        )}
        {project.data.demoURL && project.data.repoURL && <span>/</span>}
        {project.data.repoURL && (
          <Link href={project.data.repoURL} external>
            repository
          </Link>
        )}
      </nav>
    )
  }
</ArticleLayout>
