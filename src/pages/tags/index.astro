---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { getTagCounts } from "@lib/collections";
import { slugifyTag } from "@lib/utils";

const tags = await getTagCounts();
---

<PageLayout title="Tags" description="Browse all tags.">
  <Container>
    <div class="space-y-10">
      <h1 class="animate font-semibold text-black dark:text-white">Tags</h1>
      {
        tags.length > 0 ? (
          <div class="animate flex flex-wrap gap-2">
            {tags.map(([tag, count]) => (
              <a href={`/tags/${slugifyTag(tag)}/`} class="hover-card inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg">
                <span>{tag}</span>
                <span class="text-xs text-black/40 dark:text-white/40">{count}</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="animate">No tags yet.</p>
        )
      }
    </div>
  </Container>
</PageLayout>
